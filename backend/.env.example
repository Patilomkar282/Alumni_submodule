# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Server
PORT=5000
NODE_ENV=development        # Set to "production" when deploying

# MongoDB (use a dedicated DB user with least-privilege access)
MONGO_URI=mongodb+srv://alumini_connection_db:alumni123@aluminiconnectiondb.vrvr5xn.mongodb.net/?appName=aluminiconnectiondb

# JWT — Generate a strong, random 64-character secret:
#   node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_64_CHARS

# Redis (leave as-is for local dev; use Upstash or equivalent in production)
REDIS_URI=redis://127.0.0.1:6379

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# SMTP (use an App Password, not your real account password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# CORS — Frontend origin. Supports comma-separated list for multiple domains.
# Example: https://alumni-connection-module.vercel.app
# Example (multiple): https://alumni-connection-module.vercel.app,https://custom-domain.com
FRONTEND_URL=https://alumni-connection-module.vercel.app
