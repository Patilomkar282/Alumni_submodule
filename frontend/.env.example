# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# ⚠️  IMPORTANT: NEVER put the Cloudinary API Secret here!
#     The secret must only live in your server-side/backend environment.
#     Anything prefixed with VITE_ is bundled into the browser and is PUBLIC.

VITE_API_URL=http://localhost:5000

# Cloudinary — Only the cloud name and upload preset are safe to expose here.
# Use an UNSIGNED upload preset (create one in the Cloudinary dashboard).
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# DO NOT ADD VITE_CLOUDINARY_API_KEY or VITE_CLOUDINARY_API_SECRET here.
# Those are server-side secrets.
